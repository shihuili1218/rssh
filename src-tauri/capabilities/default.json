{
  "identifier": "default",
  "description": "Default capabilities for RSSH",
  "windows": ["main", "rssh-*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-set-always-on-top",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-write-text-file"
  ]
}
